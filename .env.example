ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# MongoDB Atlas / MongoDB Cloud
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=boltiply

# Minimal admin access
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-long-random-secret

# Free malware scanning provider: VirusTotal free tier
# Note: uploading CVs to VirusTotal shares files with a third-party scanner.
VIRUSTOTAL_API_KEY=your-virustotal-api-key
MALWARE_SCAN_REQUIRED=false
VIRUSTOTAL_POLL_ATTEMPTS=2
VIRUSTOTAL_POLL_DELAY_MS=1500

# Optional: store clean uploaded CV files in Cloudinary as authenticated raw assets
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_CV_FOLDER=boltiply/cvs
